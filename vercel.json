{
  "version": 2,
  "functions": {
    "api/*.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/get-holdings",     "destination": "/api/holdings.js" },
    { "source": "/api/add-holding",      "destination": "/api/holdings.js" },
    { "source": "/api/update-holding",   "destination": "/api/holdings.js" },
    { "source": "/api/delete-holding",   "destination": "/api/holdings.js" },
    { "source": "/api/signup",           "destination": "/api/auth.js" },
    { "source": "/api/login",            "destination": "/api/auth.js" },
    { "source": "/api/get-user",         "destination": "/api/auth.js" },
    { "source": "/api/save-snapshot",    "destination": "/api/portfolio.js" },
    { "source": "/api/get-history",      "destination": "/api/portfolio.js" },
    { "source": "/api/update-goal",      "destination": "/api/portfolio.js" },
    { "source": "/api/alerts",           "destination": "/api/alerts.js" },
    { "source": "/api/news",             "destination": "/api/news.js" },
    { "source": "/api/feedback",         "destination": "/api/feedback.js" },
    { "source": "/api/admin-users",      "destination": "/api/admin.js" },
    { "source": "/api/admin-feedback",   "destination": "/api/admin.js" },
    { "source": "/api/admin-stats",      "destination": "/api/admin.js" },
    { "source": "/api/paystack-init",    "destination": "/api/payments.js" },
    { "source": "/api/paystack-webhook", "destination": "/api/payments.js" },
    { "source": "/api/paystack-verify",  "destination": "/api/payments.js" },
    { "source": "/api/push-subscribe",   "destination": "/api/push.js" },
    { "source": "/api/push-send",        "destination": "/api/push.js" },
    { "source": "/api/admin-gse",        "destination": "/api/admin.js" },
    { "source": "/api/gse-data",          "destination": "/api/gse-data.js" },
    { "source": "/api/exchange-rate",    "destination": "/api/exchange-rate.js" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin",  "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization, X-Admin-Secret" },
        { "key": "Cache-Control",                "value": "no-store, no-cache, must-revalidate" },
        { "key": "Pragma",                       "value": "no-cache" }
      ]
    }
  ]
}
